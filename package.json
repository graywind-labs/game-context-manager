{
  "name": "game-context-manager",
  "version": "0.1.0",
  "description": "Local-first desktop GUI for managing agent-readable game context files.",
  "main": "out/main/index.js",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "tsc --noEmit -p tsconfig.test.json",
    "build": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && electron-vite build"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "electron": "^39.2.7",
    "electron-vite": "^4.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
